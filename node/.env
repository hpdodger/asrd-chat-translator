# Путь к папке, куда игра пишет файлы через StringToFile / FileToString
# Обычно это папка мода на игровом сервере, например:
#   C:\Program Files (x86)\Steam\steamapps\common\Alien Swarm Reactive Drop\reactivedrop
# Или на Linux-сервере:
#   /home/steam/steamapps/common/Alien Swarm Reactive Drop/reactivedrop
GAME_DATA_PATH=D:\soft\Steam\steamapps\common\Alien Swarm Reactive Drop\reactivedrop\save\vscripts

# URL LibreTranslate сервера
LIBRETRANSLATE_URL=http://localhost:5000

# На какой язык переводить (код ISO 639-1)
# en = английский, ru = русский, zh = китайский, de = немецкий и т.д.
TARGET_LANG=en

# API-ключ LibreTranslate (если сервер поднят с --api-keys, иначе оставить пустым)
LIBRETRANSLATE_API_KEY=
